{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "NFTones main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/audio_watermarker",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            "8501"
          ]
        }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "http:default",
    "process:allow-exit",
    "store:default",
    "deep-link:default",
    "updater:default"
  ]
}
