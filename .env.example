# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nftones"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_RPC_URL="https://api.devnet.solana.com"
KTRS_MINT_ADDRESS="PUT_KTRS_TOKEN_MINT_HERE"
PLATFORM_WALLET="PUT_PLATFORM_SOLANA_WALLET_HERE"

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage (for audio + cover art uploads)
# Create a project at supabase.com, then create a public bucket named "nftones".
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
