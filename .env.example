# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nftones"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_RPC_URL="https://api.devnet.solana.com"
KTRS_MINT_ADDRESS="PUT_KTRS_TOKEN_MINT_HERE"
PLATFORM_WALLET="PUT_PLATFORM_SOLANA_WALLET_HERE"

# Platform hot wallet (base58-encoded secret key, 64 bytes).
# When set, the purchase route mints an NFT to the buyer on-chain via Metaplex.
# When NOT set, the purchase still completes (status: WATERMARKED), the buyer
# gets their watermarked audio, and the mint is deferred (status: SOLD).
# Generate with: solana-keygen new -o platform-keypair.json --no-bip39-passphrase
# then base58-encode the 64-byte secret. Keep this in a secrets manager in prod.
PLATFORM_KEYPAIR_BASE58=""

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage (for audio + cover art uploads)
# Create a project at supabase.com, then create a public bucket named "nftones".
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Audio watermarker service (services/audio_watermarker, FastAPI on port 8500).
# In dev: cd services/audio_watermarker && uvicorn src.api:app --port 8500
# In prod: set this to the internal URL of the watermarker container.
NFTONES_WATERMARKER_URL="http://localhost:8500"
